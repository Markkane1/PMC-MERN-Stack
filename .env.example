# Root environment reference for local development.
# Copy the relevant values into `client/.env` and `server/.env` as needed.

# Frontend
VITE_API_URL=http://localhost:4000
VITE_API_BASE_URL=
VITE_API_PROXY=http://127.0.0.1:4000
VITE_GOOGLE_ANALYTICS_ID=
VITE_ENABLE_PWA=true
VITE_ENABLE_SERVICE_WORKER=true
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=

# Backend
PORT=4000
NODE_ENV=development
MONGO_URI=mongodb://localhost:27017/PMISDB
CORS_ORIGIN=http://localhost:5173
APP_URL=http://localhost:5173
TRUST_PROXY=false
UPLOAD_DIR=uploads

# Auth
JWT_SECRET=replace-with-at-least-32-random-characters
JWT_EXPIRES_IN=7d
JWT_REFRESH_SECRET=replace-with-a-different-strong-random-secret
JWT_REFRESH_EXPIRES_IN=30d
ALLOW_LEGACY_MASTERKEY_LOGIN=false
ENABLE_RATE_LIMITS_IN_TEST=false

# Redis / cache (optional)
REDIS_HOST=
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0

# Service integrations (optional)
PITB_SERVICE_TOKEN=
EPAY_SERVICE_TOKEN=
PLMIS_API_URL=https://plmis.pitb.gov.pk/api
PLMIS_API_KEY=
PLMIS_DEPT_CODE=PMC
PLMIS_REDIRECT_URL=

# Seed / local data helpers (optional)
# SUPERADMIN_PASSWORD is plaintext input for setup scripts and is stored as User.passwordHash.
SUPERADMIN_USERNAME=superadmin
SUPERADMIN_PASSWORD=
IDM_CLUBS_JSON=
IDM_DISTRICTS_JSON=
TEHSILS_JSON=
TEST_TOKEN=
