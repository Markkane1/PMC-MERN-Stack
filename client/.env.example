# Frontend Environment Configuration

# Backend API Configuration
# Recommended: VITE_API_URL, e.g. http://localhost:4000
# Backward-compatible alias is also supported: VITE_API_BASE_URL
VITE_API_URL=http://localhost:4000
VITE_API_BASE_URL=

# Dev-only proxy override (vite dev server)
VITE_API_PROXY=http://127.0.0.1:4000

# Analytics (Optional)
VITE_GOOGLE_ANALYTICS_ID=your-google-analytics-id

# Feature Flags
VITE_ENABLE_PWA=true
VITE_ENABLE_SERVICE_WORKER=true

