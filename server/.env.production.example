# Server (Production)
# Oracle VM recommendation: keep the app internal on 3003 and let nginx serve HTTPS publicly.
PORT=3003
NODE_ENV=production
MONGO_URI=mongodb://127.0.0.1:27017/PMISDB
CORS_ORIGIN=https://yourdomain.duckdns.org
TRUST_PROXY=true
JWT_SECRET=replace-with-at-least-32-random-characters
JWT_EXPIRES_IN=7d
JWT_REFRESH_SECRET=replace-with-a-different-strong-random-secret
JWT_REFRESH_EXPIRES_IN=30d
ALLOW_LEGACY_MASTERKEY_LOGIN=false
UPLOAD_DIR=../uploads
APP_URL=https://yourdomain.duckdns.org

# Optional integrations
REDIS_HOST=
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0
PITB_SERVICE_TOKEN=
EPAY_SERVICE_TOKEN=
PLMIS_API_URL=https://plmis.pitb.gov.pk/api
PLMIS_API_KEY=
PLMIS_DEPT_CODE=PMC
PLMIS_REDIRECT_URL=

# Optional setup helper. The superadmin bootstrap script hashes this into User.passwordHash.
SUPERADMIN_USERNAME=superadmin
SUPERADMIN_PASSWORD=


