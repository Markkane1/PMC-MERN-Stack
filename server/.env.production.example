# Server (Production)
PORT=4000
NODE_ENV=production
MONGO_URI=mongodb+srv://<user>:<password>@<cluster>/<db>?retryWrites=true&w=majority
CORS_ORIGIN=https://example.com
JWT_SECRET=replace-with-at-least-32-random-characters
JWT_EXPIRES_IN=7d
JWT_REFRESH_SECRET=replace-with-a-different-strong-random-secret
JWT_REFRESH_EXPIRES_IN=30d
ALLOW_LEGACY_MASTERKEY_LOGIN=false
UPLOAD_DIR=uploads
APP_URL=https://example.com

# Optional integrations
REDIS_HOST=
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=https://api.example.com/api/accounts/oauth/google/callback
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
GITHUB_REDIRECT_URI=https://api.example.com/api/accounts/oauth/github/callback
PITB_SERVICE_TOKEN=
EPAY_SERVICE_TOKEN=
PLMIS_API_URL=https://plmis.pitb.gov.pk/api
PLMIS_API_KEY=
PLMIS_DEPT_CODE=PMC
PLMIS_REDIRECT_URL=

