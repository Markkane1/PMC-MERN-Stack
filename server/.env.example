# Server Configuration
PORT=4000
NODE_ENV=development

# CRITICAL: Generate strong JWT_SECRET with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=replace-with-at-least-32-random-characters
JWT_EXPIRES_IN=7d
JWT_REFRESH_SECRET=replace-with-a-different-strong-random-secret
JWT_REFRESH_EXPIRES_IN=30d
ALLOW_LEGACY_MASTERKEY_LOGIN=false

# MongoDB Connection (use MongoDB Atlas or secure local instance)
MONGO_URI=mongodb://localhost:27017/PMISDB

# CORS: Set to exact frontend URL (never use *)
CORS_ORIGIN=http://localhost:5173

# Redis (optional, enables distributed cache/rate limit state)
REDIS_HOST=
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0

# File Upload Directory
UPLOAD_DIR=uploads

# Application URL (for frontend redirects)
APP_URL=http://localhost:5173

# External service bearer tokens (recommended for staging/prod integrations)
PITB_SERVICE_TOKEN=
EPAY_SERVICE_TOKEN=

# PLMIS integration (optional)
PLMIS_API_URL=https://plmis.pitb.gov.pk/api
PLMIS_API_KEY=
PLMIS_DEPT_CODE=PMC
PLMIS_REDIRECT_URL=

# Superadmin seed helper script inputs (optional)
SUPERADMIN_USERNAME=superadmin
SUPERADMIN_PASSWORD=

