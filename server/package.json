{
  "name": "pmc-be-mern",
  "version": "1.0.0",
  "private": true,
  "description": "PMC backend re-implemented in MERN (Express + MongoDB).",
  "main": "dist/server.js",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "build": "tsc",
    "start": "node dist/server.js",
    "lint": "eslint . --ext .ts",
    "seed": "tsx src/scripts/seedBaseData.ts",
    "seed:tehsils": "tsx src/scripts/seedTehsils.ts",
    "seed:idm": "tsx src/scripts/seedIdm.ts",
    "cleanup:bak": "tsx src/scripts/cleanupBackupCollections.ts",
    "db:prune-unused": "tsx src/scripts/pruneUnusedCollections.ts",
    "db:prune-unused:apply": "tsx src/scripts/pruneUnusedCollections.ts --apply",
    "superadmin:static": "tsx src/scripts/createStaticSuperAdmin.ts",
    "ensure:applicant-perms": "tsx src/scripts/ensureApplicantPermissions.ts",
    "db:index": "tsx src/scripts/createIndexes.ts",
    "load:test:baseline": "tsx src/scripts/loadTest.baseline.ts",
    "load:test:stress": "tsx src/scripts/loadTest.stress.ts",
    "load:test:sustained": "tsx src/scripts/loadTest.sustained.ts"
  },
  "dependencies": {
    "axios": "^1.13.5",
    "bcryptjs": "^2.4.3",
    "bwip-js": "^4.8.0",
    "compression": "^1.7.4",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "exceljs": "^4.4.0",
    "express": "^4.19.2",
    "express-mongo-sanitize": "^2.2.0",
    "express-rate-limit": "^7.4.1",
    "helmet": "^7.1.0",
    "ioredis": "^5.9.3",
    "jimp": "^1.6.0",
    "jsonwebtoken": "^9.0.2",
    "jsqr": "^1.4.0",
    "mongoose": "^8.8.0",
    "morgan": "^1.10.0",
    "multer": "^1.4.5-lts.1",
    "node-cache": "^5.1.2",
    "pdfkit": "^0.16.0",
    "pmc-mernstack": "file:..",
    "qrcode": "^1.5.4",
    "uuid": "^11.0.3",
    "xss": "^1.0.15",
    "zod": "^3.23.8"
